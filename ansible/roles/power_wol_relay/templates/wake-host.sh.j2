#!/bin/bash
# {{ ansible_managed }}
# Wake {{ item.name }} via Wake-on-LAN magic packet
#
# Usage: wake-{{ item.name }}.sh

set -euo pipefail

MAC="{{ item.mac }}"
HOST="{{ item.name }}"
BROADCAST="{{ item.broadcast | default('255.255.255.255') }}"

echo "Sending WOL magic packet to ${HOST} (${MAC}) via ${BROADCAST}..."

{% if ansible_os_family == "RedHat" %}
# Fedora uses 'wol' command (-h sets broadcast/host target)
/usr/bin/wol -h ${BROADCAST} ${MAC}
{% else %}
# Debian/Ubuntu uses 'wakeonlan' command (-i sets broadcast IP)
/usr/bin/wakeonlan -i ${BROADCAST} ${MAC}
{% endif %}

echo "WOL packet sent. ${HOST} should power on within a few seconds."
echo "Check status: tailscale ping ${HOST} or ssh ${HOST}"
