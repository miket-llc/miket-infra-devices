# {{ ansible_managed }}
# LiteLLM Proxy Container
# Compatible with both Docker and Podman
version: "3.9"

services:
  litellm:
    image: {{ litellm_image }}
    container_name: litellm
    env_file:
      - {{ litellm_env_path }}
    command: --config /app/config/config.yaml --host {{ litellm_bind_host }} --port {{ litellm_port }}
{% if litellm_bind_host == '0.0.0.0' or litellm_bind_tailnet | default(false) %}
    network_mode: host
{% else %}
    ports:
      - "{{ litellm_bind_host }}:{{ litellm_port }}:{{ litellm_port }}"
{% endif %}
    volumes:
      - {{ litellm_config_path }}:/app/config/config.yaml:ro,Z
    restart: unless-stopped
    healthcheck:
      # Use Python stdlib (urllib) rather than curl — the LiteLLM image is a
      # Chainguard distroless Python build that has no curl binary, so a
      # curl-based healthcheck always fails with "executable not found" and
      # leaves the container marked unhealthy regardless of service state.
      # /health/liveliness is the public, unauthenticated endpoint; /health
      # requires LITELLM_MASTER_KEY and would 401 otherwise.
      test:
        - "CMD"
        - "python"
        - "-c"
        - "import urllib.request, sys; sys.exit(0 if urllib.request.urlopen('http://127.0.0.1:{{ litellm_port }}/health/liveliness', timeout=5).status == 200 else 1)"
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s
