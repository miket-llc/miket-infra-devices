# Break-glass RDP access script
# Use only when NoMachine is unavailable
# Usage: rdp-emergency [HOSTNAME]
param([string]$Hostname = "motoko")

$Target = "${Hostname}.pangolin-vega.ts.net:3389"
Write-Host "WARNING: Using legacy RDP connection. NoMachine is preferred." -ForegroundColor Yellow
Write-Host "Connecting to $Target via RDP..." -ForegroundColor Yellow
Start-Sleep -Seconds 2

mstsc /v:$Target

